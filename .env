# Coloque aqui a URL oficial do webhook (n8n, make, typeform, etc.)
# O Vite requer que as variáveis de ambiente usadas no frontend comecem com VITE_
VITE_WEBHOOK_URL=https://n8n.davosconsulting.com.br/webhook/vapi-trigger

# Exemplo de Payload JSON que será enviado com método POST para essa URL:
# {
#   "name": "Nome Completo",
#   "phone": "11999999999",
#   "assistantId": "d5b203bf-c1af-4aa6-bac9-b13ab84f9a71" 
# }
# Note que o telefone é enviado sem *nenhum* caracter especial, apenas números.
